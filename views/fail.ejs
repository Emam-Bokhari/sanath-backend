<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Failed</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --red: #e53935;
      --red-dark: #b71c1c;
      --bg: #f4f6f5;
      --surface: rgba(255,255,255,0.85);
      --border: rgba(0,0,0,0.07);
      --text-primary: #1a1f1d;
      --text-muted: rgba(30,40,35,0.45);
      --emerald: #00b389;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
      position: relative;
    }

    /* ── Card ── */
    .card {
      position: relative; z-index: 10;
      width: min(480px, 92vw);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 3.5rem 3rem 3rem;
      text-align: center;
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      box-shadow:
        0 0 0 1px rgba(0,0,0,0.05),
        0 20px 60px rgba(0,0,0,0.08),
        0 0 40px rgba(229,57,53,0.05);
      animation: riseIn 1s cubic-bezier(0.16,1,0.3,1) forwards;
      opacity: 0;
    }
    @keyframes riseIn {
      from { opacity: 0; transform: translateY(36px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Top accent line ── */
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 50%; transform: translateX(-50%);
      width: 60%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--red), transparent);
      border-radius: 999px;
    }

    /* ── Icon ── */
    .icon-wrap {
      width: 90px; height: 90px;
      margin: 0 auto 2.2rem;
      position: relative;
      animation: popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.4s forwards;
      opacity: 0;
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(0.4) rotate(-20deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    .icon-ring {
      position: absolute; inset: 0;
      border-radius: 50%;
      border: 1.5px solid rgba(229,57,53,0.35);
      animation: ringPulse 2.5s ease-in-out 1s infinite;
    }
    .icon-ring-2 {
      position: absolute; inset: -12px;
      border-radius: 50%;
      border: 1px solid rgba(229,57,53,0.12);
      animation: ringPulse 2.5s ease-in-out 1.4s infinite;
    }
    @keyframes ringPulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.3; transform: scale(1.06); }
    }

    .icon-circle {
      width: 100%; height: 100%;
      border-radius: 50%;
      background: linear-gradient(140deg, #e53935, #b71c1c);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 40px rgba(229,57,53,0.25), 0 8px 24px rgba(0,0,0,0.15);
    }

    .icon-circle svg {
      width: 36px; height: 36px;
      stroke: #fff;
      stroke-width: 2.5;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: drawX 0.5s ease 1s forwards;
    }
    @keyframes drawX {
      to { stroke-dashoffset: 0; }
    }

    /* ── Label pill ── */
    .label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(229,57,53,0.08);
      border: 1px solid rgba(229,57,53,0.2);
      border-radius: 999px;
      padding: 4px 14px;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1.1rem;
      animation: fadeIn 0.6s ease 0.8s forwards;
      opacity: 0;
    }
    .label-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--red);
      animation: blink 1.4s ease-in-out infinite;
    }
    @keyframes blink {
      0%,100% { opacity: 1; } 50% { opacity: 0.2; }
    }

    /* ── Heading ── */
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.6rem;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 0.75rem;
      animation: fadeIn 0.6s ease 1s forwards;
      opacity: 0;
    }

    p {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 320px;
      margin: 0 auto 2.2rem;
      font-weight: 300;
      animation: fadeIn 0.6s ease 1.1s forwards;
      opacity: 0;
    }

    /* ── Retry button ── */
    .btn {
      display: inline-block;
      background: linear-gradient(135deg, #e53935, #b71c1c);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 500;
      text-decoration: none;
      padding: 0.75rem 2rem;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      letter-spacing: 0.02em;
      box-shadow: 0 4px 16px rgba(229,57,53,0.25);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      margin-bottom: 2rem;
      animation: fadeIn 0.6s ease 1.2s forwards;
      opacity: 0;
    }
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(229,57,53,0.35);
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
      margin: 0 0 1.5rem;
      animation: fadeIn 0.6s ease 1.3s forwards;
      opacity: 0;
    }

    /* ── Footer note ── */
    .footer-note {
      font-size: 0.75rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      animation: fadeIn 0.6s ease 1.4s forwards;
      opacity: 0;
    }
    .footer-note svg {
      width: 13px; height: 13px;
      stroke: var(--emerald);
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="icon-wrap">
      <div class="icon-ring-2"></div>
      <div class="icon-ring"></div>
      <div class="icon-circle">
        <svg viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </div>
    </div>

    <div class="label">
      <span class="label-dot"></span>
      Transaction Failed
    </div>

    <h1>Payment<br>Failed</h1>
    <p>Your payment could not be processed. Please check your details and try again.</p>

    <a href="#" class="btn">Try Again</a>

    <div class="divider"></div>

    <div class="footer-note">
      <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Secured by <strong style="color: var(--text-primary); margin: 0 2px;">Stripe</strong> — PCI DSS Compliant
    </div>
  </div>

</body>
</html>