<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Successful</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --emerald: #00b389;
      --emerald-dark: #007a5e;
      --emerald-glow: rgba(0, 179, 137, 0.18);
      --gold: #c9a84c;
      --bg: #f4f6f5;
      --surface: rgba(255,255,255,0.85);
      --border: rgba(0,0,0,0.07);
      --text-primary: #1a1f1d;
      --text-muted: rgba(30,40,35,0.45);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
      position: relative;
    }

    /* ── Ambient background ── */
    .bg-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(90px);
      pointer-events: none;
    }
    .orb-1 {
      width: 520px; height: 520px;
      background: radial-gradient(circle, rgba(0,179,137,0.13), transparent 70%);
      top: -120px; left: -100px;
      animation: drift 14s ease-in-out infinite alternate;
    }
    .orb-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(201,168,76,0.08), transparent 70%);
      bottom: -80px; right: -80px;
      animation: drift 18s ease-in-out infinite alternate-reverse;
    }
    .orb-3 {
      width: 250px; height: 250px;
      background: radial-gradient(circle, rgba(0,179,137,0.07), transparent 70%);
      top: 50%; left: 60%;
      animation: drift 10s ease-in-out infinite alternate;
    }
    @keyframes drift {
      from { transform: translate(0,0) scale(1); }
      to   { transform: translate(30px,20px) scale(1.08); }
    }

    /* ── Grid lines ── */
    .grid {
      position: fixed; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Particles ── */
    .particle {
      position: fixed;
      width: 2px; height: 2px;
      border-radius: 50%;
      background: var(--emerald);
      opacity: 0;
      animation: floatUp var(--dur, 8s) ease-in var(--delay, 0s) infinite;
    }
    @keyframes floatUp {
      0%   { opacity: 0; transform: translateY(0) scale(1); }
      10%  { opacity: 0.7; }
      90%  { opacity: 0.3; }
      100% { opacity: 0; transform: translateY(-100vh) scale(0); }
    }

    /* ── Card ── */
    .card {
      position: relative; z-index: 10;
      width: min(480px, 92vw);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 3.5rem 3rem 3rem;
      text-align: center;
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      box-shadow:
        0 0 0 1px rgba(0,0,0,0.05),
        0 20px 60px rgba(0,0,0,0.08),
        0 0 40px rgba(0,179,137,0.05);
      animation: riseIn 1s cubic-bezier(0.16,1,0.3,1) forwards;
      opacity: 0;
    }
    @keyframes riseIn {
      from { opacity: 0; transform: translateY(36px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Top accent line ── */
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 50%; transform: translateX(-50%);
      width: 60%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--emerald), transparent);
      border-radius: 999px;
    }

    /* ── Icon ── */
    .icon-wrap {
      width: 90px; height: 90px;
      margin: 0 auto 2.2rem;
      position: relative;
      animation: popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.4s forwards;
      opacity: 0;
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(0.4) rotate(-20deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    .icon-ring {
      position: absolute; inset: 0;
      border-radius: 50%;
      border: 1.5px solid rgba(0,179,137,0.35);
      animation: ringPulse 2.5s ease-in-out 1s infinite;
    }
    .icon-ring-2 {
      position: absolute; inset: -12px;
      border-radius: 50%;
      border: 1px solid rgba(0,179,137,0.12);
      animation: ringPulse 2.5s ease-in-out 1.4s infinite;
    }
    @keyframes ringPulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.3; transform: scale(1.06); }
    }

    .icon-circle {
      width: 100%; height: 100%;
      border-radius: 50%;
      background: linear-gradient(140deg, #00b389, #006b55);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 40px rgba(0,179,137,0.35), 0 8px 24px rgba(0,0,0,0.4);
    }

    .icon-circle svg {
      width: 36px; height: 36px;
      stroke: #fff;
      stroke-width: 2.5;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: drawCheck 0.5s ease 1s forwards;
    }
    @keyframes drawCheck {
      to { stroke-dashoffset: 0; }
    }

    /* ── Label pill ── */
    .label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(0,179,137,0.1);
      border: 1px solid rgba(0,179,137,0.2);
      border-radius: 999px;
      padding: 4px 14px;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--emerald);
      margin-bottom: 1.1rem;
      animation: fadeIn 0.6s ease 0.8s forwards;
      opacity: 0;
    }
    .label-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--emerald);
      animation: blink 1.4s ease-in-out infinite;
    }
    @keyframes blink {
      0%,100% { opacity: 1; } 50% { opacity: 0.2; }
    }

    /* ── Heading ── */
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.6rem;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 0.75rem;
      animation: fadeIn 0.6s ease 1s forwards;
      opacity: 0;
    }

    p {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 320px;
      margin: 0 auto 2.2rem;
      font-weight: 300;
      animation: fadeIn 0.6s ease 1.1s forwards;
      opacity: 0;
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
      margin: 0 0 1.5rem;
      animation: fadeIn 0.6s ease 1.3s forwards;
      opacity: 0;
    }

    /* ── Footer note ── */
    .footer-note {
      font-size: 0.75rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      animation: fadeIn 0.6s ease 1.4s forwards;
      opacity: 0;
    }
    .footer-note svg {
      width: 13px; height: 13px;
      stroke: var(--emerald);
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-orb orb-3"></div>
  <div class="grid"></div>

  <!-- Particles -->
  <script>
    for (let i = 0; i < 22; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.cssText = `
        left: ${Math.random() * 100}vw;
        bottom: ${Math.random() * 20}vh;
        --dur: ${7 + Math.random() * 8}s;
        --delay: ${Math.random() * 10}s;
        width: ${1 + Math.random() * 2}px;
        height: ${1 + Math.random() * 2}px;
        opacity: 0;
      `;
      document.body.appendChild(p);
    }
  </script>

  <div class="card">
    <div class="icon-wrap">
      <div class="icon-ring-2"></div>
      <div class="icon-ring"></div>
      <div class="icon-circle">
        <svg viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
    </div>

    <div class="label">
      <span class="label-dot"></span>
      Transaction Complete
    </div>

    <h1>Payment<br>Successful</h1>
    <p>Your transaction has been securely processed and confirmed.</p>

    <div class="divider"></div>

    <div class="footer-note">
      <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Secured by <strong style="color: var(--text-primary); margin: 0 2px;">Stripe</strong> — PCI DSS Compliant
    </div>
  </div>

</body>
</html>